VITE_FIREBASE_API_KEY="AIzaSyAGU9FTOelHYghBd2KhTIQGYBpuacYBJgk"
VITE_FIREBASE_AUTH_DOMAIN="garra-de-aguia-pg.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="garra-de-aguia-pg"
VITE_FIREBASE_STORAGE_BUCKET="garra-de-aguia-pg.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="204499771784"
VITE_FIREBASE_APP_ID="1:204499771784:web:b0f672c7898ddd2050da3d"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="" # Deixe em branco se utilizar o banco de dados padrão "(default)"

