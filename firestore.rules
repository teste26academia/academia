rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper para verificar se o usuário está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper para verificar se o usuário é o administrador principal pelo e-mail
    function isMainAdminEmail() {
      return isSignedIn() && 
             request.auth.token != null && 
             request.auth.token.email != null && 
             request.auth.token.email == "deciopadovanijr@gmail.com";
    }

    // Retorna o perfil do usuário atual do Firestore (se existir)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica se o usuário tem cargo de Administrador (case-insensitive)
    function isAdmin() {
      return isSignedIn() && (
        isMainAdminEmail() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null &&
         'role' in getUserData() &&
         (getUserData().role == "ADMIN" || 
          getUserData().role == "admin" || 
          getUserData().role == "Admin" ||
          getUserData().role == "ADMINISTRADOR" ||
          getUserData().role == "administrador"))
      );
    }
    
    // Verifica se o usuário tem cargo de Instrutor/Professor (case-insensitive)
    function isInstructor() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData() != null &&
        'role' in getUserData() &&
        (getUserData().role == "INSTRUTOR" || 
         getUserData().role == "instrutor" || 
         getUserData().role == "PROFESSOR" || 
         getUserData().role == "professor")
      );
    }

    // Verifica se o usuário é dono do próprio ID correspondente
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper para verificar se o usuário é o dono do registro de aluno correspondente
    function isStudentOwner(alunoId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null &&
         'alunoId' in getUserData() &&
         getUserData().alunoId != null && 
         getUserData().alunoId == alunoId) ||
        (resource != null && 'data' in resource && 'userId' in resource.data && resource.data.userId == request.auth.uid) ||
        (resource != null && 'data' in resource && 'email' in resource.data && request.auth.token != null && request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );
    }

    // --- REGRAS POR COLEÇÃO (ROBUSTAS E COMPATÍVEIS) ---

    // 1. users (Perfis de Usuários)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && (
        isMainAdminEmail() || 
        (!request.resource.data.keys().hasAny(['permissions', 'cargo']) && 
         ('role' in request.resource.data && (request.resource.data.role == "ALUNO" || request.resource.data.role == "aluno") || !request.resource.data.keys().hasAny(['role'])))
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isInstructor() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'cargo'])) ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'cargo']))
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    // 1.5. instrutores
    match /instrutores/{instrutorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 2. alunos (Fichas dos Alunos)
    match /alunos/{alunoId} {
      // Admins e Instrutores podem ler tudo. Alunos podem ler se o e-mail corresponder ao deles.
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'email' in resource.data && request.auth.token != null && request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );
      // Apenas administradores e professores/instrutores adicionam ou deletam alunos, ou o próprio aluno ao se auto-matricular
      allow create: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (request.resource != null && 'data' in request.resource && 'userId' in request.resource.data && request.resource.data.userId == request.auth.uid)
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        isInstructor() ||
        (isStudentOwner(alunoId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'cpf', 'rg', 'telefone', 'celular', 'endereco', 'foto', 'responsavel'
        ]))
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    // 3. turmas
    match /turmas/{turmaId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 4. presencas (Chamadas e Solicitações de Presença)
    match /presencas/{presencaId} {
      // Qualquer usuário logado pode ler se for admin/instrutor ou se for o registro do próprio aluno
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         resource.data.alunoId == getUserData().alunoId)
      );
      // Permitir criação se for admin/instrutor ou solicitação vinda do próprio aluno logado
      allow create: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (request.resource != null && 'data' in request.resource && 'status' in request.resource.data && 'alunoId' in request.resource.data &&
         request.resource.data.status == "PENDING" && 
         request.resource.data.alunoId != null && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData() != null && 'alunoId' in getUserData() &&
         request.resource.data.alunoId == getUserData().alunoId)
      );
      allow update: if isSignedIn() && (isAdmin() || isInstructor());
      allow delete: if isSignedIn() && isAdmin();
    }

    // 5. mensalidades (Financeiro)
    match /mensalidades/{mensalidadeId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         resource.data.alunoId == getUserData().alunoId)
      );
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 6. graduacoes (Histórico de Graduação)
    match /graduacoes/{graduacaoId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         resource.data.alunoId == getUserData().alunoId)
      );
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 7. exames (Avaliações Técnicas)
    match /exames/{exameId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         resource.data.alunoId == getUserData().alunoId)
      );
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 8. configuracoes (Configurações Gerais)
    match /configuracoes/{configuracaoId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 9. produtos
    match /produtos/{produtoId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 10. vendas
    match /vendas/{vendaId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         resource.data.alunoId == getUserData().alunoId)
      );
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 11. familias
    match /familias/{familiaId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         getUserData().alunoId != null && 
         resource != null && 'data' in resource && 'alunosIds' in resource.data &&
         getUserData().alunoId in resource.data.alunosIds)
      );
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 12. graduacoes_config
    match /graduacoes_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isInstructor());
    }

    // 13. aluno_modalidades
    match /aluno_modalidades/{alModId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         resource.data.alunoId == getUserData().alunoId)
      );
      allow write: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         (request.resource != null && 'data' in request.resource && 'alunoId' in request.resource.data &&
          request.resource.data.alunoId == getUserData().alunoId))
      );
    }
  }
}
