rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- SEGURANÇA GLOBAL E DEFESA DE DADOS ---

    // Bloqueio padrão (Catch-All) para Segurança de Zero-Trust
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper para verificar se o usuário está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Identificação do Administrador Principal por e-mail (Seguro contra Spoofing)
    function isMainAdmin() {
      return isSignedIn() &&
             request.auth.token != null &&
             'email' in request.auth.token &&
             request.auth.token.email == "deciopadovanijr@gmail.com";
    }

    // Retorna o perfil do usuário atual de forma resiliente
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica se o usuário tem cargo de Administrador (Sem falhas na ausência do registro)
    function isAdmin() {
      return isMainAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData() != null &&
        'role' in getUserData() &&
        (getUserData().role == "ADMIN" || 
         getUserData().role == "admin" || 
         getUserData().role == "Admin" ||
         getUserData().role == "ADMINISTRADOR" ||
         getUserData().role == "administrador")
      );
    }

    // Verifica se o usuário tem cargo de Instrutor/Professor (Robusto)
    function isInstructor() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData() != null &&
             'role' in getUserData() &&
             (getUserData().role == "INSTRUTOR" || 
              getUserData().role == "instrutor" || 
              getUserData().role == "PROFESSOR" || 
              getUserData().role == "professor");
    }

    // Helper de controle de propriedade de identificação do Aluno
    function isStudentOwner(alunoId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData() != null &&
         'alunoId' in getUserData() &&
         getUserData().alunoId == alunoId) ||
        (resource != null && 'data' in resource && 'userId' in resource.data && resource.data.userId == request.auth.uid) ||
        (resource != null && 'data' in resource && 'email' in resource.data && request.auth.token != null && 'email' in request.auth.token && resource.data.email == request.auth.token.email)
      );
    }

    // Validação estática de IDs para prevenção de injeção de lixo (ID Poisoning Guard)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- BLUEPRINTS DE VALIDAÇÃO DE ENTIDADES ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'nome', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role is string && (data.role == "ADMIN" || data.role == "admin" || data.role == "INSTRUTOR" || data.role == "instrutor" || data.role == "ALUNO" || data.role == "aluno");
    }

    function isValidInstrutor(data) {
      return data.keys().hasAll(['id', 'nome', 'funcao', 'telefone', 'email', 'ativo']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.funcao is string && data.funcao.size() <= 150 &&
             data.telefone is string && data.telefone.size() <= 50 &&
             data.email is string && data.email.size() <= 200 &&
             data.ativo is bool;
    }

    function isValidAluno(data) {
      return data.keys().hasAll(['id', 'nome', 'email', 'status', 'statusFinanceiro']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.email is string && data.email.size() <= 200;
    }

    function isValidTurma(data) {
      return data.keys().hasAll(['id', 'nomeEstilo', 'instrutorId', 'instrutorNome', 'diasSemana', 'horario', 'categoria', 'capacidade']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nomeEstilo is string && data.nomeEstilo.size() <= 200 &&
             data.instrutorId is string && data.instrutorId.size() <= 128 &&
             data.instrutorNome is string && data.instrutorNome.size() <= 200 &&
             data.diasSemana is list &&
             data.horario is string && data.horario.size() <= 150 &&
             data.categoria is string &&
             data.capacidade is number;
    }

    function isValidPresenca(data) {
      return data.keys().hasAll(['id', 'alunoId', 'data', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.alunoId is string && data.alunoId.size() <= 128 &&
             data.data is string && data.data.size() <= 50 &&
             data.status is string;
    }

    function isValidMensalidade(data) {
      return data.keys().hasAll(['id', 'alunoId', 'referencia', 'vencimento', 'valor', 'desconto', 'valorFinal', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.alunoId is string && data.alunoId.size() <= 128 &&
             data.referencia is string && data.referencia.size() <= 50 &&
             data.vencimento is string && data.vencimento.size() <= 50 &&
             data.valor is number &&
             data.desconto is number &&
             data.valorFinal is number &&
             data.status is string;
    }

    function isValidGraduacao(data) {
      return data.keys().hasAll(['id', 'alunoId', 'graduacaoAnterior', 'graduacaoNova', 'dataGraduacao', 'avaliador', 'resultado']) &&
             data.id is string && data.id.size() <= 128 &&
             data.alunoId is string && data.alunoId.size() <= 128 &&
             data.graduacaoAnterior is string && data.graduacaoAnterior.size() <= 150 &&
             data.graduacaoNova is string && data.graduacaoNova.size() <= 150 &&
             data.dataGraduacao is string && data.dataGraduacao.size() <= 50 &&
             data.avaliador is string && data.avaliador.size() <= 200 &&
             data.resultado is string;
    }

    function isValidExame(data) {
      return data.keys().hasAll(['id', 'alunoId', 'graduacaoPretendida', 'avaliador', 'dataExame', 'notaTecnica', 'notaTeorica', 'resultado']) &&
             data.id is string && data.id.size() <= 128 &&
             data.alunoId is string && data.alunoId.size() <= 128 &&
             data.graduacaoPretendida is string && data.graduacaoPretendida.size() <= 150 &&
             data.avaliador is string && data.avaliador.size() <= 200 &&
             data.dataExame is string && data.dataExame.size() <= 50 &&
             data.notaTecnica is number &&
             data.notaTeorica is number &&
             data.resultado is string;
    }

    function isValidConfig(data) {
      return data.keys().hasAll(['id', 'descontoFamiliarPercentualPadrao', 'descontoFamiliarFixoPadrao', 'avisoMural', 'contatoSuporte', 'enderecoAcademia']) &&
             data.id is string && data.id.size() <= 128 &&
             data.descontoFamiliarPercentualPadrao is number &&
             data.descontoFamiliarFixoPadrao is number &&
             data.avisoMural is string &&
             data.contatoSuporte is string &&
             data.enderecoAcademia is string;
    }

    function isValidProduto(data) {
      return data.keys().hasAll(['id', 'nome', 'categoria', 'estoque', 'ativo']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.categoria is string && data.categoria.size() <= 150 &&
             data.estoque is number &&
             data.ativo is bool;
    }

    function isValidVenda(data) {
      return data.keys().hasAll(['id', 'alunoId', 'produtoId', 'quantidade', 'valorUnitario', 'valorTotal', 'formaPagamento', 'data']) &&
             data.id is string && data.id.size() <= 128 &&
             data.alunoId is string && data.alunoId.size() <= 128 &&
             data.produtoId is string && data.produtoId.size() <= 128 &&
             data.quantidade is number &&
             data.valorUnitario is number &&
             data.valorTotal is number &&
             data.formaPagamento is string &&
             data.data is string;
    }

    function isValidFamilia(data) {
      return data.keys().hasAll(['id', 'nomeFamilia', 'alunosIds']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nomeFamilia is string && data.nomeFamilia.size() <= 200 &&
             data.alunosIds is list;
    }

    function isValidGraduacoesConfig(data) {
      return data.keys().hasAll(['id', 'modalidade', 'ordem', 'graduacao', 'faixa', 'ativo']) &&
             data.id is string && data.id.size() <= 128 &&
             data.modalidade is string && data.modalidade.size() <= 150 &&
             data.ordem is number &&
             data.graduacao is string && data.graduacao.size() <= 150 &&
             data.faixa is string && data.faixa.size() <= 100 &&
             data.ativo is bool;
    }

    function isValidAlunoModalidade(data) {
      return data.keys().hasAll(['id', 'alunoId', 'modalidade', 'graduacaoAtual', 'faixaAtual', 'ordemGraduacao', 'dataUltimaGraduacao', 'ativo']) &&
             data.id is string && data.id.size() <= 128 &&
             data.alunoId is string && data.alunoId.size() <= 128 &&
             data.modalidade is string && data.modalidade.size() <= 150 &&
             data.graduacaoAtual is string && data.graduacaoAtual.size() <= 150 &&
             data.faixaAtual is string && data.faixaAtual.size() <= 100 &&
             data.ordemGraduacao is number &&
             data.dataUltimaGraduacao is string && data.dataUltimaGraduacao.size() <= 50 &&
             data.ativo is bool;
    }

    // --- DEFINIÇÕES DE REGRAS POR COLEÇÃO ESPECÍFICA ---

    // 1. users (Perfis de Usuários)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUserProfile(request.resource.data) && (
        isMainAdmin() || 
        (!request.resource.data.keys().hasAny(['permissions', 'cargo']) && 
         ('role' in request.resource.data && (request.resource.data.role == "ALUNO" || request.resource.data.role == "aluno")))
      );
      allow update: if isSignedIn() && isValidId(userId) && (
        isAdmin() || 
        (isInstructor() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'cargo'])) ||
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'cargo']))
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    // 1.5. instrutores
    match /instrutores/{instrutorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(instrutorId) && (isAdmin() || isInstructor());
    }

    // 2. alunos (Fichas dos Alunos)
    match /alunos/{alunoId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'email' in resource.data && request.auth.token != null && 'email' in request.auth.token && resource.data.email == request.auth.token.email)
      );
      allow create: if isSignedIn() && isValidId(alunoId) && (
        isAdmin() || 
        isInstructor() || 
        (request.resource != null && 'data' in request.resource && 'userId' in request.resource.data && request.resource.data.userId == request.auth.uid)
      );
      allow update: if isSignedIn() && isValidId(alunoId) && (
        isAdmin() || 
        isInstructor() ||
        (isStudentOwner(alunoId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'cpf', 'rg', 'telefone', 'celular', 'endereco', 'foto', 'responsavel'
        ]))
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    // 3. turmas
    match /turmas/{turmaId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(turmaId) && (isAdmin() || isInstructor());
    }

    // 4. presencas (Chamadas e Solicitações de Presença)
    match /presencas/{presencaId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && isStudentOwner(resource.data.alunoId))
      );
      allow create: if isSignedIn() && isValidId(presencaId) && (
        isAdmin() || 
        isInstructor() || 
        (request.resource != null && 'data' in request.resource && 'status' in request.resource.data && 'alunoId' in request.resource.data &&
         request.resource.data.status == "PENDING" && isStudentOwner(request.resource.data.alunoId))
      );
      allow update: if isSignedIn() && isValidId(presencaId) && (isAdmin() || isInstructor());
      allow delete: if isSignedIn() && isAdmin();
    }

    // 5. mensalidades (Financeiro)
    match /mensalidades/{mensalidadeId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && isStudentOwner(resource.data.alunoId))
      );
      allow write: if isSignedIn() && isValidId(mensalidadeId) && (isAdmin() || isInstructor());
    }

    // 6. graduacoes (Histórico de Graduação)
    match /graduacoes/{graduacaoId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && isStudentOwner(resource.data.alunoId))
      );
      allow write: if isSignedIn() && isValidId(graduacaoId) && (isAdmin() || isInstructor());
    }

    // 7. exames (Avaliações Técnicas)
    match /exames/{exameId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && isStudentOwner(resource.data.alunoId))
      );
      allow write: if isSignedIn() && isValidId(exameId) && (isAdmin() || isInstructor());
    }

    // 8. configuracoes (Configurações Gerais)
    match /configuracoes/{configuracaoId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(configuracaoId) && (isAdmin() || isInstructor());
    }

    // 9. produtos
    match /produtos/{produtoId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(produtoId) && (isAdmin() || isInstructor());
    }

    // 10. vendas
    match /vendas/{vendaId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && isStudentOwner(resource.data.alunoId))
      );
      allow write: if isSignedIn() && isValidId(vendaId) && (isAdmin() || isInstructor());
    }

    // 11. familias
    match /familias/{familiaId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData() != null && 'alunoId' in getUserData() &&
         getUserData().alunoId != null && 
         resource != null && 'data' in resource && 'alunosIds' in resource.data &&
         getUserData().alunoId in resource.data.alunosIds)
      );
      allow write: if isSignedIn() && isValidId(familiaId) && (isAdmin() || isInstructor());
    }

    // 12. graduacoes_config
    match /graduacoes_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(configId) && (isAdmin() || isInstructor());
    }

    // 13. aluno_modalidades
    match /aluno_modalidades/{alModId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isInstructor() || 
        (resource != null && 'data' in resource && 'alunoId' in resource.data && isStudentOwner(resource.data.alunoId))
      );
      allow write: if isSignedIn() && isValidId(alModId) && (
        isAdmin() || 
        isInstructor() || 
        (request.resource != null && 'data' in request.resource && 'alunoId' in request.resource.data && isStudentOwner(request.resource.data.alunoId))
      );
    }
  }
}
