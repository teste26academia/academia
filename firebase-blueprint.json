{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Perfil de usuário contendo autorização de cargo",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "INSTRUTOR", "ALUNO"] },
        "alunoId": { "type": "string" }
      },
      "required": ["uid", "nome", "email", "role"]
    },
    "Aluno": {
      "title": "Aluno",
      "description": "Dados do aluno matriculado na academia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "nome": { "type": "string" },
        "cpf": { "type": "string" },
        "rg": { "type": "string" },
        "dataNascimento": { "type": "string" },
        "telefone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "endereco": { "type": "string" },
        "responsavel": { "type": "string" },
        "foto": { "type": "string" },
        "dataMatricula": { "type": "string" },
        "graduacaoAtual": { "type": "string" },
        "dataUltimaGraduacao": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"] },
        "turmaId": { "type": "string" },
        "modalidade": { "type": "string" },
        "observacoes": { "type": "string" },
        "statusFinanceiro": { "type": "string", "enum": ["EM DIA", "PENDENTE", "ATRASADO", "ISENTO", "Em Dia", "Atrasado", "Pendente", "Isento"] }
      },
      "required": [
        "id",
        "userId",
        "nome",
        "cpf",
        "rg",
        "dataNascimento",
        "telefone",
        "whatsapp",
        "email",
        "endereco",
        "responsavel",
        "foto",
        "dataMatricula",
        "graduacaoAtual",
        "dataUltimaGraduacao",
        "status",
        "turmaId",
        "modalidade",
        "statusFinanceiro"
      ]
    },
    "Turma": {
      "title": "Turma",
      "description": "Turmas de treino configuradas na academia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nomeEstilo": { "type": "string" },
        "instrutorId": { "type": "string" },
        "instrutorNome": { "type": "string" },
        "diasSemana": { "type": "array" },
        "horario": { "type": "string" },
        "categoria": { "type": "string", "enum": ["Iniciante", "Intermediário", "Avançado", "Misto"] },
        "capacidade": { "type": "number" }
      },
      "required": ["id", "nomeEstilo", "instrutorId", "instrutorNome", "diasSemana", "horario", "categoria", "capacidade"]
    },
    "Presenca": {
      "title": "Presenca",
      "description": "Registro de presença/chamada e solicitação de check-in de alunos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "turmaId": { "type": "string" },
        "alunoId": { "type": "string" },
        "modalidade": { "type": "string" },
        "data": { "type": "string" },
        "horario": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED", "Presente", "Faltou", "Justificado"] },
        "confirmadoPor": { "type": "string" }
      },
      "required": ["id", "alunoId", "modalidade", "data", "status"]
    },
    "Mensalidade": {
      "title": "Mensalidade",
      "description": "Histórico de mensalidades geradas para os alunos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alunoId": { "type": "string" },
        "referencia": { "type": "string" },
        "vencimento": { "type": "string" },
        "valor": { "type": "number" },
        "desconto": { "type": "number" },
        "valorFinal": { "type": "number" },
        "status": { "type": "string", "enum": ["EM DIA", "PENDENTE", "ATRASADO", "ISENTO", "Em Dia", "Atrasado", "Pendente", "Isento"] },
        "dataPagamento": { "type": "string" }
      },
      "required": ["id", "alunoId", "referencia", "vencimento", "valor", "desconto", "valorFinal", "status"]
    },
    "Graduacao": {
      "title": "Graduacao",
      "description": "Controle de exames e histórico de graduações de faixa",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alunoId": { "type": "string" },
        "graduacaoAnterior": { "type": "string" },
        "graduacaoNova": { "type": "string" },
        "dataGraduacao": { "type": "string" },
        "avaliador": { "type": "string" },
        "observacoes": { "type": "string" },
        "resultado": { "type": "string" }
      },
      "required": ["id", "alunoId", "graduacaoAnterior", "graduacaoNova", "dataGraduacao", "avaliador", "resultado"]
    },
    "GlobalConfigs": {
      "title": "GlobalConfigs",
      "description": "Configurações globais da academia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "descontoFamiliarPercentualPadrao": { "type": "number" },
        "descontoFamiliarFixoPadrao": { "type": "number" },
        "avisoMural": { "type": "string" },
        "contatoSuporte": { "type": "string" },
        "enderecoAcademia": { "type": "string" }
      },
      "required": ["id", "descontoFamiliarPercentualPadrao", "descontoFamiliarFixoPadrao", "avisoMural", "contatoSuporte", "enderecoAcademia"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfis de usuários associados ao login Firebase"
    },
    "/alunos/{alunoId}": {
      "schema": "Aluno",
      "description": "Informações cadastrais e financeiras dos alunos"
    },
    "/turmas/{turmaId}": {
      "schema": "Turma",
      "description": "Cadastro e controle de turmas"
    },
    "/presencas/{presencaId}": {
      "schema": "Presenca",
      "description": "Registro de presenças e controle de chamadas"
    },
    "/mensalidades/{mensalidadeId}": {
      "schema": "Mensalidade",
      "description": "Controle financeiro de mensalidades e status de cobrança"
    },
    "/graduacoes/{graduacaoId}": {
      "schema": "Graduacao",
      "description": "Registros de exames de faixa e históricos"
    },
    "/configuracoes/{configuracaoId}": {
      "schema": "GlobalConfigs",
      "description": "Configurações gerais do sistema"
    }
  }
}
