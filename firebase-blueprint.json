{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Perfil de usuário contendo autorização de cargo",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "INSTRUTOR", "ALUNO"] },
        "alunoId": { "type": "string" }
      },
      "required": ["uid", "nome", "email", "role"]
    },
    "Aluno": {
      "title": "Aluno",
      "description": "Dados do aluno matriculado na academia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "celular": { "type": "string" },
        "cpf": { "type": "string" },
        "dataNascimento": { "type": "string" },
        "graduacao": { "type": "string" },
        "dataUltimaGraduacao": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"] },
        "turmaId": { "type": "string" },
        "planoTipo": { "type": "string", "enum": ["1x_semana", "2x_semana", "3x_semana", "4x_semana", "outro"] },
        "mensalidade": { "type": "number" },
        "descontoFamiliaTipo": { "type": "string", "enum": ["percentual", "fixo", "nenhum"] },
        "descontoFamiliaValor": { "type": "number" },
        "statusFinanceiro": { "type": "string", "enum": ["Em Dia", "Atrasado", "Pendente"] },
        "observacoes": { "type": "string" },
        "endereco": { "type": "string" }
      },
      "required": ["id", "nome", "email", "celular", "cpf", "dataNascimento", "graduacao", "dataUltimaGraduacao", "status", "turmaId", "planoTipo", "mensalidade", "descontoFamiliaTipo", "descontoFamiliaValor", "statusFinanceiro"]
    },
    "Turma": {
      "title": "Turma",
      "description": "Turmas de treino configuradas na academia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nomeEstilo": { "type": "string" },
        "instrutorId": { "type": "string" },
        "instrutorNome": { "type": "string" },
        "diasSemana": { "type": "array" },
        "horario": { "type": "string" },
        "categoria": { "type": "string", "enum": ["Iniciante", "Intermediário", "Avançado", "Misto"] },
        "capacidade": { "type": "number" }
      },
      "required": ["id", "nomeEstilo", "instrutorId", "instrutorNome", "diasSemana", "horario", "categoria", "capacidade"]
    },
    "Presenca": {
      "title": "Presenca",
      "description": "Registro de presença/chamada e solicitação de check-in de alunos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "turmaId": { "type": "string" },
        "alunoId": { "type": "string" },
        "alunoNome": { "type": "string" },
        "data": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED", "Presente", "Faltou", "Justificado"] },
        "observacao": { "type": "string" },
        "solicitadoPorAluno": { "type": "boolean" }
      },
      "required": ["id", "turmaId", "alunoId", "alunoNome", "data", "status"]
    },
    "Pagamento": {
      "title": "Pagamento",
      "description": "Histórico de pagamentos e mensalidades geradas para os alunos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alunoId": { "type": "string" },
        "alunoNome": { "type": "string" },
        "valor": { "type": "number" },
        "dataVencimento": { "type": "string" },
        "dataPagamento": { "type": "string" },
        "status": { "type": "string", "enum": ["Pago", "Pendente", "Atrasado"] },
        "metodo": { "type": "string", "enum": ["PIX", "Cartão", "Dinheiro", "Boleto"] }
      },
      "required": ["id", "alunoId", "alunoNome", "valor", "dataVencimento", "status"]
    },
    "HistoricoGraduacao": {
      "title": "HistoricoGraduacao",
      "description": "Histórico de exames de faixa e graduações",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alunoId": { "type": "string" },
        "alunoNome": { "type": "string" },
        "sashAnterior": { "type": "string" },
        "sashNovo": { "type": "string" },
        "dataExame": { "type": "string" },
        "avaliador": { "type": "string" },
        "notaTecnica": { "type": "number" },
        "notaFilosofica": { "type": "number" },
        "status": { "type": "string", "enum": ["Acesso Permitido", "Aprovado", "Pendente"] }
      },
      "required": ["id", "alunoId", "alunoNome", "sashAnterior", "sashNovo", "dataExame", "avaliador", "notaTecnica", "notaFilosofica", "status"]
    },
    "GlobalConfigs": {
      "title": "GlobalConfigs",
      "description": "Configurações globais da academia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "descontoFamiliarPercentualPadrao": { "type": "number" },
        "descontoFamiliarFixoPadrao": { "type": "number" },
        "avisoMural": { "type": "string" },
        "contatoSuporte": { "type": "string" },
        "enderecoAcademia": { "type": "string" }
      },
      "required": ["id", "descontoFamiliarPercentualPadrao", "descontoFamiliarFixoPadrao", "avisoMural", "contatoSuporte", "enderecoAcademia"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfis de usuários associados ao login Firebase"
    },
    "/alunos/{alunoId}": {
      "schema": "Aluno",
      "description": "Informações cadastrais e financeiras dos alunos"
    },
    "/turmas/{turmaId}": {
      "schema": "Turma",
      "description": "Cadastro e controle de turmas"
    },
    "/presencas/{presencaId}": {
      "schema": "Presenca",
      "description": "Registro de presenças e controle de chamadas"
    },
    "/mensalidades/{mensalidadeId}": {
      "schema": "Pagamento",
      "description": "Controle financeiro de mensalidades e status de cobrança"
    },
    "/exames/{exameId}": {
      "schema": "HistoricoGraduacao",
      "description": "Registros de exames de faixa e notas técnicas e filosóficas"
    },
    "/configuracoes/{configuracaoId}": {
      "schema": "GlobalConfigs",
      "description": "Configurações gerais do sistema"
    }
  }
}
